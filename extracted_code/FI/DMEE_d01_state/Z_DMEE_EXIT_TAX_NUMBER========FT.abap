FORM PARAMETER_COMPARE USING NAME
                       CHANGING VALUE.
  CASE NAME.
    WHEN 'O_VALUE'.
      IF %_OO_VALUE <> %_VO_VALUE.
        VALUE = 'X'.
      ELSE.
        CLEAR VALUE.
      ENDIF.
    WHEN 'C_VALUE'.
      IF %_OC_VALUE <> %_VC_VALUE.
        VALUE = 'X'.
      ELSE.
        CLEAR VALUE.
      ENDIF.
    WHEN 'N_VALUE'.
      IF %_ON_VALUE <> %_VN_VALUE.
        VALUE = 'X'.
      ELSE.
        CLEAR VALUE.
      ENDIF.
    WHEN 'P_VALUE'.
      IF %_OP_VALUE <> %_VP_VALUE.
        VALUE = 'X'.
      ELSE.
        CLEAR VALUE.
      ENDIF.
    WHEN 'I_TAB'.
      IF %_OI_TAB[] <> %_VI_TAB[].
        VALUE = 'X'.
      ELSE.
        CLEAR VALUE.
      ENDIF.
  ENDCASE.
ENDFORM.
