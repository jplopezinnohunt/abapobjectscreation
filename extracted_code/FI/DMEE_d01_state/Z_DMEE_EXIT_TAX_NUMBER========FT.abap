REPORT Z_DMEE_EXIT_TAX_NUMBER========FT.
* 2.0
*
DATA: TIME1 TYPE P, TIME2 TYPE P, RUNTIME(30), DEBUG, ATRA.
DATA: RC LIKE SY-SUBRC , V_RC LIKE SY-SUBRC.
DATA: DESTI LIKE RFCDES-RFCDEST.
DATA: FIELDNAME LIKE SY-REPID.
DATA: G_UPPER TYPE C.         "Gross/Kleinschreibung
*
TABLES : EUFUNC.
DATA: BEGIN OF UNTERSCHIED,            " Unterschiede bei Testdur
        PARAMETER(30),
        ALT(200),
        NEU(200),                      " laufen
      END OF UNTERSCHIED.
*
DATA : D102N_EXPORTKEY LIKE FUNCTDIR.
*
DATA : BEGIN OF EXPORTKEY,
         DATAID LIKE EUFUNC-NUMMER,
         SEQID  LIKE EUFUNC-SEQID,
       END OF EXPORTKEY.
DATA : BEGIN OF EXCEPTIONS OCCURS 10,
         NAME(30),
       END OF EXCEPTIONS.
DATA : VEXCEPTION(30).
DATA : OEXCEPTION(30).
DATA : NR2(250) TYPE C.
DATA : TABLEN TYPE I.
DATA : EX TYPE REF TO CX_ROOT.
DATA : DESCR_REF TYPE REF TO CL_ABAP_TYPEDESCR.
DATA : RESULTAT(30) TYPE C.
DATA : REST(30)     TYPE C.
*
DATA: %_II_TREE_TYPE TYPE DMEE_TREETYPE_ABA.
DATA: %_II_TREE_ID TYPE DMEE_TREEID_ABA.
DATA: %_II_ITEM(200).
DATA: %_II_PARAM(200).
DATA: %_II_UPARAM(200).
DATA: %_II_EXTENSION TYPE DMEE_EXIT_INTERFACE_ABA.
DATA: %_OO_VALUE(200),
      %_VO_VALUE(200).
DATA: %_OC_VALUE(200),
      %_VC_VALUE(200).
DATA: %_ON_VALUE(200),
      %_VN_VALUE(200).
DATA: %_OP_VALUE(200),
      %_VP_VALUE(200).
DATA: BEGIN OF %_II_TAB OCCURS 1,
        DEFAULT(200),
      END OF %_II_TAB.
*
DATA: BEGIN OF %_OI_TAB OCCURS 1,
        DEFAULT(200),
      END OF %_OI_TAB.
*
DATA: BEGIN OF %_VI_TAB OCCURS 1,
        DEFAULT(200),
      END OF %_VI_TAB.
*
FORM EXISTENCE_CHECK CHANGING VARIA.
  VARIA = 1.
ENDFORM.
FORM FUNCTION_CALL.
  CLEAR %_OO_VALUE.
  CLEAR %_OC_VALUE.
  CLEAR %_ON_VALUE.
  CLEAR %_OP_VALUE.
CLEAR %_OI_TAB.
REFRESH %_OI_TAB.
LOOP AT %_II_TAB.
  %_OI_TAB = %_II_TAB.
  APPEND %_OI_TAB.
ENDLOOP.
*  TRANSAKTION = 'Repo', PROGRAM = REPORT
  IF ATRA = '1'.
    SET RUN TIME ANALYZER ON %_INTERNAL.
  ENDIF.
IF DESTI IS INITIAL.
IF DEBUG = '1'. BREAK-POINT AT NEXT APPLICATION STATEMENT.
ENDIF.
DEBUG = SPACE.
GET RUN TIME FIELD TIME1.
CALL FUNCTION 'Z_DMEE_EXIT_TAX_NUMBER'
EXPORTING
I_TREE_TYPE = %_II_TREE_TYPE
I_TREE_ID = %_II_TREE_ID
I_ITEM = %_II_ITEM
I_PARAM = %_II_PARAM
I_UPARAM = %_II_UPARAM
I_EXTENSION = %_II_EXTENSION
IMPORTING
O_VALUE = %_OO_VALUE
C_VALUE = %_OC_VALUE
N_VALUE = %_ON_VALUE
P_VALUE = %_OP_VALUE
TABLES
I_TAB = %_OI_TAB.
  IF ATRA = '1'.
    SET RUN TIME ANALYZER OFF %_INTERNAL.
  ENDIF.
ELSE.
GET RUN TIME FIELD TIME1.
*  TRANSAKTION = 'Repo', PROGRAM = REPORT
  IF ATRA = '1'.
    SET RUN TIME ANALYZER ON %_INTERNAL.
  ENDIF.
IF DESTI = 'SPACE'.
  DESTI = ' '.
ENDIF.
CALL FUNCTION 'Z_DMEE_EXIT_TAX_NUMBER' DESTINATION DESTI
EXPORTING
I_TREE_TYPE = %_II_TREE_TYPE
I_TREE_ID = %_II_TREE_ID
I_ITEM = %_II_ITEM
I_PARAM = %_II_PARAM
I_UPARAM = %_II_UPARAM
I_EXTENSION = %_II_EXTENSION
IMPORTING
O_VALUE = %_OO_VALUE
C_VALUE = %_OC_VALUE
N_VALUE = %_ON_VALUE
P_VALUE = %_OP_VALUE
TABLES
I_TAB = %_OI_TAB.
  IF ATRA = '1'.
    SET RUN TIME ANALYZER OFF %_INTERNAL.
  ENDIF.
  ENDIF.
  GET RUN TIME FIELD TIME2.
  RC = SY-SUBRC.
  CLEAR EXCEPTIONS.
  READ TABLE EXCEPTIONS INDEX RC.
  IF SY-SUBRC = 0.
  OEXCEPTION = EXCEPTIONS-NAME.
  ELSE.
  OEXCEPTION = RESULTAT.
  ENDIF.
  TIME1 = TIME2 - TIME1.
  WRITE TIME1 TO RUNTIME.
  CONDENSE RUNTIME.
ENDFORM.

