REFRESH MESS_TAB.

SELECT * FROM T000 INTO TABLE I000.

LOOP AT I000 WHERE MANDT <> '000'.

  PERFORM APPEND_MESS_TAB
  USING   '3' ' '
          'E' '56' '666'
          'X'
          I000-MANDT SPACE SPACE SPACE.

  IF GET_TIME = 'X'.
    GET TIME. T0 = SY-UZEIT.
  ENDIF.

  T000 = I000.
  REFRESH: LANGUS,
           706D,
           702P, 702Q,
           702E, 702G, 702I, 702J, 702N,
           702O, 702R, 702W, 702X, 702Y,
           706E, 706G, 706I, 706J, 706N,
           706O, 706R, 706W, 706X, 706Y,
           702H, 702V.

************************************************************************
* Die im Mandanten benutzten Sprachschlüssel bestimmen
************************************************************************
  SELECT * FROM T706T CLIENT SPECIFIED
                      WHERE MANDT = T000-MANDT.
    MOVE-CORRESPONDING T706T TO LANGUS.
    COLLECT LANGUS.
  ENDSELECT.
  DESCRIBE TABLE LANGUS LINES LI.
  PERFORM DRUCK_T USING 'LANGUS' LI.

************************************************************************
* Die, die schon da sind
************************************************************************
  SELECT * FROM T706E CLIENT SPECIFIED
                      WHERE MANDT = T000-MANDT.
    MOVE-CORRESPONDING T706E TO 702E.
    APPEND 702E.
  ENDSELECT.
  PERFORM DRUCK_T USING 'T706E' SY-DBCNT.

  SELECT * FROM T706G CLIENT SPECIFIED
                      WHERE MANDT = T000-MANDT.
    MOVE-CORRESPONDING T706G TO 702G.
    APPEND 702G.
  ENDSELECT.
  PERFORM DRUCK_T USING 'T706G' SY-DBCNT.

  SELECT * FROM T706R CLIENT SPECIFIED
                      WHERE MANDT = T000-MANDT.
    MOVE-CORRESPONDING T706R TO 702R.
    APPEND 702R.
  ENDSELECT.
  PERFORM DRUCK_T USING 'T706R' SY-DBCNT.

