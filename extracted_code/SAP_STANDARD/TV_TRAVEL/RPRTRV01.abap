* T702E, T706E füllen
  LOOP AT LANGUS.
    706E-SPRAS = LANGUS-SPRAS.
    PERFORM REDD04T USING 706E-SPRAS 'KZPMF' 706E-FZTXT.
    LOOP AT 702E.
      MOVE-CORRESPONDING 702E TO 706E.
      706E-FZTXT+21(4) = 706E-KZPMF.
      PERFORM DRUCK_E USING 702E.
      PERFORM DRUCK_E USING 706E.
      APPEND 706E.
    ENDLOOP.
  ENDLOOP.

  DESCRIBE TABLE 702E LINES LI.
  PERFORM DRUCK_T USING '702E' LI.
  DESCRIBE TABLE 706E LINES LI.
  PERFORM DRUCK_T USING '706E' LI.

  IF MODIF = 'X'.
    INSERT T702E CLIENT SPECIFIED FROM TABLE 702E
                 ACCEPTING DUPLICATE KEYS.
    PERFORM DRUCK_T USING 'T702E' SY-DBCNT.

    INSERT T706E CLIENT SPECIFIED FROM TABLE 706E
                 ACCEPTING DUPLICATE KEYS.
    PERFORM DRUCK_T USING 'T706E' SY-DBCNT.
  ENDIF.

