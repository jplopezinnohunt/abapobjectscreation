* Füllen der Kürzungsregeln
* T702H füllen
  SELECT * FROM T706H CLIENT SPECIFIED WHERE MANDT = T000-MANDT
                                       AND   MOREI = '99'.
    PERFORM DRUCK_E USING T706H.
    MOVE-CORRESPONDING T706H TO 702H.
    702H-MOREI = T706H-ERGRU.
    702H-ERKLA = '0'.
    702H-ERGRU = '00'.
    IF 702H-LNDGR = 'DOM'.
      702H-LNDGR = 'AT '.
    ENDIF.
    IF 702H-LNDGR = 'ABR'.
      702H-LNDGR = '   '.
    ENDIF.
    702H-NUMFZ = T706H-BETFZ.
    702H-NUMFA = T706H-BETFA.
    702H-DENTR = T706H-BETKU.
    APPEND 702H.
  ENDSELECT.

  DESCRIBE TABLE 702H LINES LI.
  PERFORM DRUCK_T USING '702H' LI.

  IF MODIF = 'X'.
    INSERT T702H CLIENT SPECIFIED FROM TABLE 702H
                 ACCEPTING DUPLICATE KEYS.
    PERFORM DRUCK_T USING 'T702H' SY-DBCNT.
  ENDIF.

