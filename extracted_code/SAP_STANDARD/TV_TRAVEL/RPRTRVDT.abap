        REINR LIKE PTK42-REINR,
        LFDNR LIKE PTK42-LFDNR,
        DRUCK LIKE PTK42-DRUCK,
        ANTRG LIKE PTK42-ANTRG,
        ABREC LIKE PTK42-ABREC,
        UEBLG LIKE PTK42-UEBLG,
        UEBRF LIKE PTK42-UEBRF,
        UEBDT LIKE PTK42-UEBDT,
        DATV1 LIKE PTK42-DATV1,
        UHRV1 LIKE PTK42-UHRV1,
        DATB1 LIKE PTK42-DATB1,
        UHRB1 LIKE PTK42-UHRB1,
        ZLAND LIKE PTK42-ZLAND,
        ZORT1 LIKE PTK42-ZORT1,
        KUNDE LIKE PTK42-KUNDE,
