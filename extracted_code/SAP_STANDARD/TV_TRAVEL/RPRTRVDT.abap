
************************************************************************
******** Data-definition TS-Cluster *Stand 3.0A ************************
************************************************************************

DATA: BEGIN OF TS-KEY,                 "Schlüssel TS-Cluster
*       INCLUDE STRUCTURE PTK40.
        PERNR LIKE PTK40-PERNR,
      END OF TS-KEY.

DATA: BEGIN OF OTS-VERSION,            "Version TS-Cluster
*       INCLUDE STRUCTURE PTK41.
        SAPRL LIKE PTK41-SAPRL,
        NUMBR LIKE PTK41-NUMBR,
      END OF OTS-VERSION.

DATA: BEGIN OF TS-VERSION,
        SAPRL LIKE OTS-VERSION-SAPRL,
        NUMBR LIKE OTS-VERSION-NUMBR VALUE '02',
      END OF TS-VERSION.

DATA: BEGIN OF REISEN OCCURS 100,      "Tabelle Reisen
*       INCLUDE STRUCTURE PTK42.
        ABRJ1 LIKE PTK42-ABRJ1,
