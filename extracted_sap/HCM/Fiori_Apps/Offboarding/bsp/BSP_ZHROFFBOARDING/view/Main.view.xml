<mvc:View
    controllerName="com.hr.unesco.yhrappoffboarding.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns="sap.m"
    height="100%"
>
    <f:DynamicPage
        id="dynamicPage"
        headerExpanded="true"
    >
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title
                        text="HR Approval Requests"
                        level="H2"
                    />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title> 
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <VBox
                    class="sapUiMediumMarginBottom"
                    width="100%"
                >
                    <HBox
                        class="sapUiTinyMarginBottom"
                        justifyContent="SpaceBetween"
                    >
                        <VBox width="32%">
                            <Label
                                text="Month"
                                class="sapUiTinyMarginBottom"
                            />
                            <ComboBox
                                id="monthCombo"
                                placeholder="Select a month"
                                selectionChange=".onFilterPress"
                                width="100%"
                            >
                                <core:Item
                                    key="01"
                                    text="January"
                                />
                                <core:Item
                                    key="02"
                                    text="February"
                                />
                                <core:Item
                                    key="03"
                                    text="March"
                                />
                                <core:Item
                                    key="04"
                                    text="April"
                                />
                                <core:Item
                                    key="05"
                                    text="May"
                                />
                                <core:Item
                                    key="06"
                                    text="June"
                                />
                                <core:Item
                                    key="07"
                                    text="July"
                                />
                                <core:Item
                                    key="08"
                                    text="August"
                                />
                                <core:Item
                                    key="09"
                                    text="September"
                                />
                                <core:Item
                                    key="10"
                                    text="October"
                                />
                                <core:Item
                                    key="11"
                                    text="November"
                                />
                                <core:Item
                                    key="12"
                                    text="December"
                                />
                            </ComboBox>
                        </VBox>

                        <VBox width="32%">
                            <Label
                                text="Year"
                                class="sapUiTinyMarginBottom"
                            />
                            <ComboBox
                                id="yearCombo"
                                placeholder="Select a year"
                                selectionChange=".onFilterPress"
                                width="100%"
                            >
                                <core:Item
                                    key="2023"
                                    text="2023"
                                />
                                <core:Item
                                    key="2024"
                                    text="2024"
                                />
                                <core:Item
                                    key="2025"
                                    text="2025"
                                />
                                <core:Item
                                    key="2026"
                                    text="2026"
                                />
                            </ComboBox>
                        </VBox>

                        <VBox width="32%">
                            <Label
                                text="Employee Name"
                                class="sapUiTinyMarginBottom"
                            />
                            <Input
                                id="employeeNameInput"
                                placeholder="Enter employee name or ID"
                                liveChange=".onFilterPress"
                                width="100%"
                            />
                        </VBox>
                    </HBox>

                    <HBox
                        class="sapUiTinyMarginBottom"
                        justifyContent="SpaceBetween"
                    >
                        <VBox width="24%">
                            <Label
                                text="Category"
                                class="sapUiTinyMarginBottom"
                            />
                            <ComboBox
                                id="categoryCombo"
                                placeholder="Select a category"
                                width="100%"
                                selectionChange=".onFilterPress"
                                items="{
                                    path: 'offboardingModel>/EmployeeGroupSet'
                                }"
                            >
                                <core:Item
                                    key="{offboardingModel>ID}"
                                    text="{offboardingModel>TEXT}"
                                />
                            </ComboBox>
                        </VBox>

                        <VBox width="24%">
                            <Label
                                text="Contract Type"
                                class="sapUiTinyMarginBottom"
                            />
                            <ComboBox
                                id="contractTypeCombo"
                                placeholder="Select a contract type"
                                selectionChange=".onFilterPress"
                                width="100%"
                                items="{
                                    path: 'offboardingModel>/ContractTypeSet'
                                }"
                            >
                                <core:Item
                                    key="{offboardingModel>ID}"
                                    text="{offboardingModel>TEXT}"
                                />
                            </ComboBox>
                        </VBox>

                        <VBox width="24%">
                            <Label
                                text="Action Type"
                                class="sapUiTinyMarginBottom"
                            />
                            <ComboBox
                                id="actionTypeCombo"
                                placeholder="Select an action type"
                                selectionChange=".onFilterPress"
                                width="100%"
                            >
                                <core:Item
                                    key="00"
                                    text="Separation"
                                />
                                <core:Item
                                    key="01"
                                    text="Leave without pay"
                                />
                            </ComboBox>
                        </VBox>

                        <VBox width="24%">
                            <Label
                                text="Status"
                                class="sapUiTinyMarginBottom"
                            />
                            <ComboBox
                                id="statusCombo"
                                placeholder="Select status"
                                selectionChange=".onFilterPress"
                                width="100%"
                            >
                                <core:Item
                                    key="IN_PROGRESS"
                                    text="In Progress"
                                />
                                <core:Item
                                    key="CANCELLED"
                                    text="Cancelled"
                                />
                                <core:Item
                                    key="COMPLETED"
                                    text="Completed"
                                />
                            </ComboBox>
                        </VBox>
                    </HBox>

                    <HBox
                        justifyContent="End"
                        class="sapUiTinyMarginTop"
                    >
                        <Button
                            text="Go"
                            type="Emphasized"
                            press=".onFilterPress"
                            class="sapUiTinyMarginEnd"
                        />
                        <Button
                            text="Reset Filters"
                            type="Default"
                            press=".onResetFilters"
                        />
                    </HBox>

                    <OverflowToolbar
                        design="Transparent"
                        class="sapUiMediumMarginTop"
                    >
                        <Button
                            icon="sap-icon://collapse"
                            tooltip="Toggle Filters"
                            press="onToggleFilters"
                            type="Transparent"
                        />
                        <ToolbarSeparator />
                        <SearchField
                            id="tableSearchField"
                            width="300px"
                            placeholder="Search in table..."
                            liveChange="onTableSearch"
                        />
                        <ToolbarSpacer />
                        <Button
                            icon="sap-icon://sort-ascending"
                            tooltip="Sort ascending"
                            press="onSortAscending"
                            type="Transparent"
                        />
                        <Button
                            icon="sap-icon://sort-descending"
                            tooltip="Sort descending"
                            press="onSortDescending"
                            type="Transparent"
                        />
                        <Button
                            icon="sap-icon://action-settings"
                            tooltip="Column settings"
                            press="onSettingsPress"
                            type="Transparent"
                        />
                        <Button
                            icon="sap-icon://excel-attachment"
                            tooltip="Export to Excel"
                            press="onExportToExcelAdvanced"
                            type="Transparent"
                        />
                        <Button
                            icon="sap-icon://full-screen"
                            tooltip="Full screen"
                            press="onToggleFullScreen"
                            type="Transparent"
                        />
                    </OverflowToolbar>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <Table
                id="requestTable"
                mode="SingleSelectLeft"
                growing="true"
                growingThreshold="20"
                items="{path: 'offboardingModel>/RequestSet'}"
                updateFinished=".onTableUpdateFinished"
            >
                <columns>
                    <Column width="120px">
                        <customData>
                            <core:CustomData
                                key="property"
                                value="CreatorPernr"
                            />
                        </customData>
                        <Text text="Employee ID" />
                    </Column>
                    <Column width="200px">
                        <customData>
                            <core:CustomData
                                key="property"
                                value="CreatorName"
                            />
                        </customData>
                        <Text text="Employee Name" />
                    </Column>
                    <Column width="200px">
                        <customData>
                            <core:CustomData
                                key="property"
                                value="Reason"
                            />
                        </customData>
                        <Text text="Reason" />
                    </Column>
                    <Column width="120px">
                        <customData>
                            <core:CustomData
                                key="property"
                                value="EffectiveDate"
                            />
                        </customData>
                        <Text text="Effective Date" />
                    </Column>
                    <Column width="120px">
                        <customData>
                            <core:CustomData
                                key="property"
                                value="Endda"
                            />
                        </customData>
                        <Text text="End Date" />
                    </Column>
                    <Column
                        width="80px"
                        hAlign="Center"
                    >
                        <customData>
                            <core:CustomData
                                key="property"
                                value="SeparationLetter"
                            />
                        </customData>
                        <Text text="Letter" />
                    </Column>
                    <Column
                        width="80px"
                        hAlign="Center"
                    >
                        <customData>
                            <core:CustomData
                                key="property"
                                value="Checkout"
                            />
                        </customData>
                        <Text text="Checkout" />
                    </Column>
                    <Column
                        width="120px"
                        hAlign="Center"
                    >
                        <customData>
                            <core:CustomData
                                key="property"
                                value="SalarySuspense"
                            />
                        </customData>
                        <Text text="Salary Suspense" />
                    </Column>
                    <Column
                        width="120px"
                        hAlign="Center"
                    >
                        <customData>
                            <core:CustomData
                                key="property"
                                value="ActionIRIS"
                            />
                        </customData>
                        <Text text="Action iRIS" />
                    </Column>
                    <Column
                        width="80px"
                        hAlign="Center"
                    >
                        <customData>
                            <core:CustomData
                                key="property"
                                value="Paf"
                            />
                        </customData>
                        <Text text="Paf" />
                    </Column>
                    <Column visible="false">
                        <customData>
                            <core:CustomData
                                key="property"
                                value="Guid"
                            />
                        </customData>
                        <Text text="Guid" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        type="Navigation"
                        press=".onNavToDetail"
                    >
                        <cells>
                            <Text text="{offboardingModel>CreatorPernr}" />
                            <Text
                                text="{parts: [{path:'offboardingModel>CreatorFname'},{path:'offboardingModel>CreatorLname'}], formatter: '.formatFullName'}"
                            />
                            <Text text="{offboardingModel>Reason}" />
                            <Text
                                text="{path:'offboardingModel>EffectiveDate', formatter:'.formatDate'}"
                            />
                            <Text
                                text="{path:'offboardingModel>Endda', formatter:'.formatDate'}"
                            />
                            <CheckBox
                                selected="{path:'offboardingModel>SepSlwop', formatter:'.formatCheckBox'}"
                                editable="false"
                            />
                            <CheckBox
                                selected="{path:'offboardingModel>Checkout', formatter:'.formatCheckBox'}"
                                editable="false"
                            />
                            <CheckBox
                                selected="{path:'offboardingModel>SalarySuspense', formatter:'.formatCheckBox'}"
                                editable="false"
                            />
                            <CheckBox
                                selected="{path:'offboardingModel>Action_Rec_Iris', formatter:'.formatCheckBox'}"
                                editable="false"
                            />
                            <CheckBox
                                selected="{path:'offboardingModel>Paf', formatter:'.formatCheckBox'}"
                                editable="false"
                            />
                            <Text
                                text="{path:'offboardingModel>Guid', formatter:'.formatGuid'}"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>