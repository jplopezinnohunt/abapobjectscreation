<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns:m="sap.m" xmlns:l="sap.ui.layout" xmlns:u="sap.uxap" xmlns:f="sap.ui.layout.form">

      <m:Panel
	    headerText="{i18n>upload.tab.offboarding}"
	    expandable="true"
	    expanded="true"
	    class="sapUiTinyMarginTop sapUiTinyMarginBottom">
	
	    <m:Table
	        id="offboardingDocumentsTable"
	        items="{selectedRequest>/DocumentLinks}"
	        width="100%">
	        <m:columns>
	            <m:Column width="50%">
	                <m:Label
	                    text="{i18n>upload.table.header.name}"
	                    design="Bold"/>
	            </m:Column>
	            <!--<m:Column width="20%">-->
	            <!--    <m:Label-->
	            <!--        text="{i18n>upload.table.header.ressource}"-->
	            <!--        design="Bold"/>-->
	            <!--</m:Column>-->
	            <m:Column width="50%">
	                <m:Label
	                    text="{i18n>upload.table.header.link}"
	                    design="Bold"/>
	            </m:Column>
	        </m:columns>
	
	        <m:items>
	            <m:ColumnListItem>
	                <m:cells>
	                    <m:Text text="{selectedRequest>DocumentName}"/>
	                    <!--<m:Button-->
                     <!--         icon="sap-icon://show"-->
                     <!--         press=".onShowDocument"-->
                     <!--         tooltip="{i18n>upload.tooltip.view.ressource}"-->
                     <!--         type="Transparent"/>-->
                              
	                    <m:Link
	                        text="{selectedRequest>LinkTxt}"
	                        href="{selectedRequest>Url}"
	                        target="_blank"/>
	                        
	                </m:cells>
	            </m:ColumnListItem>
	        </m:items>
	    </m:Table>
	
	     <!--Exit Interview Invitation -->
	    <m:VBox id="invitation" class="sapUiSmallMarginTop">
	        <m:Text text="{i18n>exitTexts1}" wrapping="true"/>
	        <m:Text text="{i18n>exitTexts2}"/>
	        <m:Link text="{i18n>exitTextsURL}" href="mailto:Offboarding@unesco.org"/>
	    </m:VBox>
	</m:Panel>
</core:FragmentDefinition>