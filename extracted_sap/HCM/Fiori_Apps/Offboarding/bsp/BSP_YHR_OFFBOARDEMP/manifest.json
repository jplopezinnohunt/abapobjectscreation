{
	"_version": "1.40.0",
	"sap.app": {
		"id": "com.hr.unesco.yhrappoffboardingemp",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:basic",
			"version": "1.18.5",
			"toolsId": "e9f1abaf-2a84-4654-b4d6-57b366856d02"
		},
		"dataSources": {
			"ZHRF_OFFBOARD": {
				"uri": "/sap/opu/odata/sap/ZHRF_OFFBOARD_SRV/",
				"type": "OData",
				"settings": {
					"odataVersion": "2.0",
					"localUri": "localService/metadata.xml",
					"annotations": []
				}
			}
		},
		"supportedLocales": [
			"",
			"en"
		],
		"fallbackLocale": "en"
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.139.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.ui.export": {},
				"sap.f": {},
				"sap.ui.comp": {}
			}
		},
		"extends": {
			"component": "com.hr.unesco.yhrappoffboardingemp",
			"extensions": {
				"sap.ui.viewExtensions": {
					"com.hr.unesco.yhrappoffboardingemp.view.Upload": {
						"extensionPanelRessourceAndLinks": {
							"className": "sap.ui.core.Fragment",
							"fragmentName": "com.hr.unesco.yhrappoffboardingemp.view.fragments.PanelRessourceAndLinks",
							"type": "XML"
						}
					},
					"com.hr.unesco.yhrappoffboardingemp.view.Detail": {
						"extensionPanelRessourceAndLinks": {
							"className": "sap.ui.core.Fragment",
							"fragmentName": "com.hr.unesco.yhrappoffboardingemp.view.fragments.PanelRessourceAndLinks",
							"type": "XML"
						}
					}
				}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "com.hr.unesco.yhrappoffboardingemp.i18n.i18n"
				}
			},
			"offboardingModel": {
				"dataSource": "ZHRF_OFFBOARD",
				"settings": {
					"defaultOperationMode": "Server",
					"defaultBindingMode": "OneWay",
					"defaultCountMode": "Inline",
					"useBatch": true,
					"refreshAfterChange": false,
					"metadataUrlParams": {
						"sap-value-list": "none"
					},
					"defaultUpdateMethod": "PUT"
				}
			}
		},
		"resources": {
			"css": [
				{
					"uri": "css/style.css"
				}
			]
		},
		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"controlAggregation": "pages",
				"controlId": "app",
				"transition": "slide",
				"type": "View",
				"viewType": "XML",
				"path": "com.hr.unesco.yhrappoffboardingemp.view",
				"async": true
			},
			"routes": [
				{
					"name": "RouteEmployee",
					"pattern": "",
					"target": "TargetEmployee"
				},
				{
					"name": "RouteUpload",
					"pattern": "Upload/{RequestId}",
					"target": "TargetUpload"
				},
				{
					"name": "RouteDetail",
					"pattern": "Detail/{RequestId}",
					"target": "TargetDetail"
				},
				{
					"name": "RouteResourceNotFound",
					"pattern": "ResourceNotFound",
					"target": "ResourceNotFound"
				}
			],
			"targets": {
				"TargetEmployee": {
					"id": "Employee",
					"name": "Employee",
					"level": 1
				},
				"TargetUpload": {
					"id": "Upload",
					"name": "Upload",
					"level": 2
				},
				"TargetDetail": {
					"id": "Detail",
					"name": "Detail",
					"level": 2
				},
				"ResourceNotFound": {
					"id": "ResourceNotFound",
					"name": "ResourceNotFound"
				}
			}
		},
		"rootView": {
			"viewName": "com.hr.unesco.yhrappoffboardingemp.view.App",
			"type": "XML",
			"id": "App",
			"async": true
		}
	},
	"sap.platform.abap": {
		"uri": "/sap/bc/ui5_ui5/sap/yhr_offboardemp",
		"_version": "1.1.0"
	}
}