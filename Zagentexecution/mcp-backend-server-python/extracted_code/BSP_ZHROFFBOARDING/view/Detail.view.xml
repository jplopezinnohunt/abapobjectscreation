<mvc:View
    controllerName="com.hr.unesco.yhrappoffboarding.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Page
        id="pageDetail"
        title="Detail of Employee Request"
        class="sapUiContentPadding"
        showNavButton="true"
        navButtonPress=".onNavBack"
    >
        <content>
            <IconTabBar
                id="iconTabBar"
                expandable="false"
            >
                <items>
                    <IconTabFilter
                        text="Details"
                        key="details"
                        icon="sap-icon://detail-view"
                    >
                        <VBox
                            class="sapUiLargeMargin"
                            alignItems="Center"
                            justifyContent="Center"
                            width="100%"
                        >
                            <VBox width="900px">
                                <VBox
                                    class="sapUiSmallMarginBottom"
                                    alignItems="Center"
                                >
                                    <Title
                                        text="{parts:[{path:'selectedRequest>/CreatorLname'},{path:'selectedRequest>/CreatorFname'}], formatter:'.formatFullName'}"
                                        level="H1"
                                    />
                                    <Text
                                        text="ID: {selectedRequest>/CreatorPernr}"
                                        class="sapUiTinyMarginTop"
                                    />
                                    <Text
                                        text="{path:'selectedRequest>/Guid', formatter:'.formatGuidReadable'}"
                                        class="sapUiTinyMarginTop sapUiTinyFont"
                                    />
                                    <!-- âœ… CORRECTION 1 : ObjectStatus avec TOUS les paramÃ¨tres -->
                                    <ObjectStatus
                                        text="{
                                            parts: [
                                                {path: 'selectedRequest>/Closed'},
                                                {path: 'selectedRequest>/RequestInit'},
                                                {path: 'selectedRequest>/SepSlwop'},
                                                {path: 'selectedRequest>/Sep_Letter_Staf'},
                                                {path: 'selectedRequest>/Sep_Slwop_Oth_Parties'},
                                                {path: 'selectedRequest>/Checkout'},
                                                {path: 'selectedRequest>/Travel'},
                                                {path: 'selectedRequest>/Shipment'},
                                                {path: 'selectedRequest>/SalarySuspense'},
                                                {path: 'selectedRequest>/Action_Rec_Iris'},
                                                {path: 'selectedRequest>/Paf'}
                                            ],
                                            formatter: '.formatRequestStatus'
                                        }"
                                        state="{
                                            parts: [
                                                {path: 'selectedRequest>/Closed'},
                                                {path: 'selectedRequest>/RequestInit'},
                                                {path: 'selectedRequest>/SepSlwop'},
                                                {path: 'selectedRequest>/Sep_Letter_Staf'},
                                                {path: 'selectedRequest>/Sep_Slwop_Oth_Parties'},
                                                {path: 'selectedRequest>/Checkout'},
                                                {path: 'selectedRequest>/Travel'},
                                                {path: 'selectedRequest>/Shipment'},
                                                {path: 'selectedRequest>/SalarySuspense'},
                                                {path: 'selectedRequest>/Action_Rec_Iris'},
                                                {path: 'selectedRequest>/Paf'}
                                            ],
                                            formatter: '.formatRequestStatusState'
                                        }"
                                        class="sapUiLargeFont sapUiSmallMarginTop"
                                    />
                                </VBox>

                                <Panel
                                    headerText="Request Details"
                                    expandable="true"
                                    expanded="true"
                                    class="sapUiTinyMarginBottom"
                                >
                                    <content>
                                        <VBox class="sapUiSmallMargin">
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="Employee ID"
                                                    design="Bold"
                                                    width="150px"
                                                />
                                                <Text
                                                    text="{selectedRequest>/CreatorPernr}"
                                                />
                                            </HBox>
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="Employee Name"
                                                    design="Bold"
                                                    width="150px"
                                                />
                                                <Text
                                                    text="{parts:[{path:'selectedRequest>/CreatorLname'},{path:'selectedRequest>/CreatorFname'}], formatter:'.formatFullName'}"
                                                />
                                            </HBox>
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="Request ID"
                                                    design="Bold"
                                                    width="150px"
                                                />
                                                <Text
                                                    text="{path:'selectedRequest>/Guid', formatter:'.formatGuidReadable'}"
                                                />
                                            </HBox>
                                            <!-- âœ… CORRECTION 2 : ObjectStatus avec TOUS les paramÃ¨tres -->
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="Status"
                                                    design="Bold"
                                                    width="150px"
                                                />
                                                <ObjectStatus
                                                    text="{
                                                        parts: [
                                                            {path: 'selectedRequest>/Closed'},
                                                            {path: 'selectedRequest>/RequestInit'},
                                                            {path: 'selectedRequest>/SepSlwop'},
                                                            {path: 'selectedRequest>/Sep_Letter_Staf'},
                                                            {path: 'selectedRequest>/Sep_Slwop_Oth_Parties'},
                                                            {path: 'selectedRequest>/Checkout'},
                                                            {path: 'selectedRequest>/Travel'},
                                                            {path: 'selectedRequest>/Shipment'},
                                                            {path: 'selectedRequest>/SalarySuspense'},
                                                            {path: 'selectedRequest>/Action_Rec_Iris'},
                                                            {path: 'selectedRequest>/Paf'}
                                                        ],
                                                        formatter: '.formatRequestStatus'
                                                    }"
                                                    state="{
                                                        parts: [
                                                            {path: 'selectedRequest>/Closed'},
                                                            {path: 'selectedRequest>/RequestInit'},
                                                            {path: 'selectedRequest>/SepSlwop'},
                                                            {path: 'selectedRequest>/Sep_Letter_Staf'},
                                                            {path: 'selectedRequest>/Sep_Slwop_Oth_Parties'},
                                                            {path: 'selectedRequest>/Checkout'},
                                                            {path: 'selectedRequest>/Travel'},
                                                            {path: 'selectedRequest>/Shipment'},
                                                            {path: 'selectedRequest>/SalarySuspense'},
                                                            {path: 'selectedRequest>/Action_Rec_Iris'},
                                                            {path: 'selectedRequest>/Paf'}
                                                        ],
                                                        formatter: '.formatRequestStatusState'
                                                    }"
                                                />
                                            </HBox>
                                            <!-- <HBox class="sapUiTinyMarginBottom">
                                                <Label text="Action Type" design="Bold" width="150px" />
                                                <Text text="{selectedRequest>/ActionType}" />
                                            </HBox> -->
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="Effective Date"
                                                    design="Bold"
                                                    width="150px"
                                                />
                                                <Text
                                                    text="{path:'selectedRequest>/EffectiveDate', formatter:'.formatDateApproval'}"
                                                />
                                            </HBox>
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="End Date"
                                                    design="Bold"
                                                    width="150px"
                                                />
                                                <Text
                                                    text="{path:'selectedRequest>/Endda', formatter:'.formatDateApproval'}"
                                                />
                                            </HBox>
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="Reason"
                                                    design="Bold"
                                                    width="150px"
                                                />
                                                <Text
                                                    text="{selectedRequest>/Reason}"
                                                />
                                            </HBox>
                                        </VBox>
                                    </content>
                                </Panel>

                                <Panel
                                    headerText="Employee Details"
                                    expandable="true"
                                    expanded="false"
                                    class="sapUiTinyMarginBottom"
                                >
                                    <content>
                                        <VBox class="sapUiSmallMargin">
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="Personnel Number"
                                                    design="Bold"
                                                    width="140px"
                                                />
                                                <Text
                                                    text="{selectedRequest>/CreatorPernr}"
                                                />
                                            </HBox>
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="First Name"
                                                    design="Bold"
                                                    width="140px"
                                                />
                                                <Text
                                                    text="{selectedRequest>/CreatorFname}"
                                                />
                                            </HBox>
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="Last Name"
                                                    design="Bold"
                                                    width="140px"
                                                />
                                                <Text
                                                    text="{selectedRequest>/CreatorLname}"
                                                />
                                            </HBox>
                                            <HBox class="sapUiTinyMarginBottom">
                                                <Label
                                                    text="Request ID"
                                                    design="Bold"
                                                    width="140px"
                                                />
                                                <Text
                                                    text="{path:'selectedRequest>/Guid', formatter:'.formatGuidReadable'}"
                                                />
                                            </HBox>
                                        </VBox>
                                    </content>
                                </Panel>

                                <!-- SECTION WORKFLOW STATUS (CheckBox dÃ©sactivÃ©s) -->
                                <Panel
                                    headerText="Workflow Status"
                                    expandable="true"
                                    expanded="false"
                                    class="sapUiTinyMarginBottom"
                                >
                                    <content>
                                        <Table
                                            id="workflowStatusTable"
                                            items="{selectedRequest>/WorkflowStepSet}"
                                        >
                                            <columns>
                                                <Column width="10%">
                                                    <header>
                                                        <Label
                                                            text="Status"
                                                            design="Bold"
                                                        />
                                                    </header>
                                                </Column>
                                                <Column width="35%">
                                                    <header>
                                                        <Label
                                                            text="Workflow Step"
                                                            design="Bold"
                                                        />
                                                    </header>
                                                </Column>
                                                <Column width="20%">
                                                    <header>
                                                        <Label
                                                            text="Validator"
                                                            design="Bold"
                                                        />
                                                    </header>
                                                </Column>
                                                <Column width="20%">
                                                    <header>
                                                        <Label
                                                            text="Date"
                                                            design="Bold"
                                                        />
                                                    </header>
                                                </Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem>
                                                    <cells>
                                                        <!-- DÃ©sactivation du CheckBox -->
                                                        <CheckBox
                                                            selected="{path:'selectedRequest>Completed', formatter:'.formatCompletedStatus'}"
                                                            enabled="false"
                                                        />
                                                        <Text
                                                            text="{selectedRequest>StepName}"
                                                        />
                                                        <Text
                                                            text="{selectedRequest>Validator}"
                                                        />
                                                        <Text
                                                            text="{path:'selectedRequest>DATE_APPROVAL', formatter:'.formatDateApproval'}"
                                                        />
                                                    </cells>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </content>
                                </Panel>
                                <Panel
                                    headerText="Uploaded Documents"
                                    expandable="true"
                                    expanded="false"
                                    class="sapUiTinyMarginBottom"
                                >
                                    <Table
                                        id="docsTable"
                                        items="{selectedRequest>/Documents}"
                                        noDataText="No documents uploaded yet."
                                    >
                                        <columns>
                                            <Column width="25%">
                                                <header>
                                                    <Label
                                                        text="Document Name"
                                                        design="Bold"
                                                    />
                                                </header>
                                            </Column>
                                            <Column width="10%">
                                                <header>
                                                    <Label
                                                        text="Type"
                                                        design="Bold"
                                                    />
                                                </header>
                                            </Column>
                                            <Column width="8%">
                                                <header>
                                                    <Label
                                                        text="Size"
                                                        design="Bold"
                                                    />
                                                </header>
                                            </Column>
                                            <Column width="15%">
                                                <header>
                                                    <Label
                                                        text="Creator"
                                                        design="Bold"
                                                    />
                                                </header>
                                            </Column>
                                            <Column width="15%">
                                                <header>
                                                    <Label
                                                        text="Actions"
                                                        design="Bold"
                                                    />
                                                </header>
                                            </Column>
                                        </columns>

                                        <items>
                                            <ColumnListItem>
                                                <cells>
                                                    <Text
                                                        text="{selectedRequest>Filename}"
                                                    />
                                                    <Text
                                                        text="{selectedRequest>AttachTypeTxt}" 
                                                    />
                                                    <Text
                                                        text="{parts:[{path:'selectedRequest>Filesize'}], formatter:'.formatFileSize'}"
                                                    />
                                                    <Text
                                                        text="{parts:[
                            {path:'selectedRequest>CreatorFname'},
                            {path:'selectedRequest>CreatorLname'}
                        ], formatter:'.formatFullName'}"
                                                    />
                                                    <HBox>
                                                        <Button
                                                            icon="sap-icon://show"
                                                            press=".onOpenDocument"
                                                            tooltip="View"
                                                        />
                                                        <Button
                                                            icon="sap-icon://download"
                                                            press=".onDownloadDocument"
                                                            tooltip="Download"
                                                        />
                                                    </HBox>
                                                </cells>
                                            </ColumnListItem>
                                        </items>
                                    </Table>
                                </Panel>
                            </VBox>
                        </VBox>
                    </IconTabFilter>

                    <IconTabFilter
                        text="Comments"
                        key="comments"
                        icon="sap-icon://comment"
                    >
                        <VBox
                            class="sapUiLargeMargin"
                            alignItems="Center"
                            width="100%"
                        >
                            <VBox width="900px">
                                <Table
                                    id="commentsTable"
                                    items="{selectedRequest>/Commentset}"
                                    noDataText="No comments available"
                                >
                                    <columns>
                                        <Column width="25%">
                                            <header>
                                                <Label
                                                    text="Workflow Step"
                                                    design="Bold"
                                                />
                                            </header>
                                        </Column>
                                        <Column width="20%">
                                            <header>
                                                <Label
                                                    text="Validator"
                                                    design="Bold"
                                                />
                                            </header>
                                        </Column>
                                        <Column width="20%">
                                            <header>
                                                <Label
                                                    text="Date"
                                                    design="Bold"
                                                />
                                            </header>
                                        </Column>
                                        <Column width="35%">
                                            <header>
                                                <Label
                                                    text="Comment"
                                                    design="Bold"
                                                />
                                            </header>
                                        </Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem>
                                            <cells>
                                                <Text
                                                    text="{selectedRequest>STEP_NAME}"
                                                />
                                                <Text
                                                    text="{parts:[{path:'selectedRequest>UPD_FNAME'},{path:'selectedRequest>UPD_LNAME'}], formatter:'.formatFullName'}"
                                                />
                                                <Text
                                                    text="{path:'selectedRequest>DATE_APPROVAL', formatter:'.formatDateApproval'}"
                                                />
                                                <Text
                                                    text="{selectedRequest>COMMENTS}"
                                                />
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>

        <footer>
            <Bar design="Footer">
                <contentRight>
                    <Button
                        text="Update Request"
                        icon="sap-icon://edit"
                        type="Emphasized"
                        press=".onUpdateRequest"
                    />
                </contentRight>
            </Bar>
        </footer>
    </Page>
</mvc:View>