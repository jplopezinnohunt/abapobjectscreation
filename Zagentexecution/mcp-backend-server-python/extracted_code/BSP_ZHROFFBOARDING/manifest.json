{
    "_version": "1.40.0",
    "sap.app": {
        "id": "com.hr.unesco.yhrappoffboarding",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.0.1"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "@sap/generator-fiori:basic",
            "version": "1.18.5",
            "toolsId": "e9f1abaf-2a84-4654-b4d6-57b366856d02"
        },
        "dataSources": {
            "ZHRF_OFFBOARD": {
                "uri": "/sap/opu/odata/sap/ZHRF_OFFBOARD_SRV/",
                "type": "OData",
                "settings": {
                    "odataVersion": "2.0",
                    "localUri": "localService/metadata.xml",
                    "annotations": []
                }
            }
        },
        "supportedLocales": [
            "",
            "en"
        ],
        "fallbackLocale": "en"
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": true,
        "dependencies": {
            "minUI5Version": "1.139.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.ui.export": {},
                "sap.f": {},
                "sap.ui.comp": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "com.hr.unesco.yhrappoffboarding.i18n.i18n"
                }
            },
            "offboardingModel": {
                "dataSource": "ZHRF_OFFBOARD",
                "settings": {
                    "defaultOperationMode": "Server",
                    "defaultBindingMode": "OneWay",
                    "defaultCountMode": "Inline",
                    "useBatch": true,
                    "refreshAfterChange": false,
                    "metadataUrlParams": {
                        "sap-value-list": "none"
                    },
                    "defaultUpdateMethod": "PUT"
                }
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "controlAggregation": "pages",
                "controlId": "app",
                "transition": "slide",
                "type": "View",
                "viewType": "XML",
                "path": "com.hr.unesco.yhrappoffboarding.view",
                "controllerPath": "com.hr.unesco.yhrappoffboarding.controller",
                "async": true
            },
            "routes": [
                {
                    "name": "RouteMain",
                    "pattern": "",
                    "target": "TargetMain"
                },
                {
                    "name": "RouteDetail",
                    "pattern": "Detail/{RequestId}",
                    "target": "TargetDetail"
                }
            ],
            "targets": {
                "TargetMain": {
                    "id": "Main",
                    "name": "Main",
                    "level": 1
                },
                "TargetDetail": {
                    "id": "Detail",
                    "name": "Detail",
                    "viewName": "Detail",
                    "viewType": "XML",
                    "viewPath": "com.hr.unesco.yhrappoffboarding.view",
                    "level": 2
                }
            }
        },
        "rootView": {
            "viewName": "com.hr.unesco.yhrappoffboarding.view.App",
            "type": "XML",
            "id": "App",
            "async": true
        }
    },
    "sap.platform.abap": {
        "uri": "/sap/bc/ui5_ui5/sap/zhroffboarding",
        "_version": "1.1.0"
    }
}